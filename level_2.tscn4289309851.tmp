[sub_resource type="GDScript" id="GDScript_nmjpi"]
script/source = "extends CharacterBody2D

@export var speed: float = 250.0
@export var jump_velocity: float = -450.0
@export var gravity: float = 1000.0

@export var dodge_speed: float = 700.0
@export var dodge_time: float = 0.25

# --- HEALTH & TRANSFORMATION VARIABLES ---
@export var max_health: float = 100.0
var current_health: float = 100.0
var has_transformed: bool = false

# --- DOUBLE JUMP VARIABLES ---
@export var max_jumps: int = 2
var jump_count: int = 0

var is_dodging: bool = false
var dodge_timer: float = 0.0
var facing_direction: int = 1   # 1 = right, -1 = left

# --- ATTACK VARIABLES ---
var is_attacking: bool = false
@export var attack_duration: float = 0.3
var original_texture: Texture2D

@export var normal_scale: Vector2 = Vector2(1.9, 1.9) 
@export var attack_scale: Vector2 = Vector2(3.5, 3.5) 

# Asset Preloading
@onready var attack_texture = preload(\"res://nartak.png\") 
@onready var transformed_texture = preload(\"res://Pictures/narup2.png\")
# This finds the ProgressBar inside your HUD CanvasLayer
@onready var health_bar = get_tree().root.find_child(\"PlayerHealthBar\", true, false)
@onready var sprite = $Sprite2D
@onready var collision = $CollisionShape2D

func _ready():
	# 1. Initialize Health and HUD
	current_health = max_health
	if health_bar and health_bar is ProgressBar:
		health_bar.max_value = max_health
		health_bar.value = current_health
	
	# 2. Capture Starting State
	if sprite:
		original_texture = sprite.texture
		sprite.scale = normal_scale
	
	add_to_group(\"Player\")

func _physics_process(delta):
	# Apply gravity
	if not is_on_floor():
		velocity.y += gravity * delta
	else:
		# Reset jump count when landing
		jump_count = 0

	# Get movement input
	var direction = Input.get_axis(\"move_left\", \"move_right\")

	if direction != 0:
		facing_direction = sign(direction)

	# --- INPUTS ---
	
	# Attack Input (V Key)
	if Input.is_action_just_pressed(\"attack\") and not is_attacking and not is_dodging:
		start_attack()

	# Dodge Input (Shift)
	if Input.is_action_just_pressed(\"dodge\") and not is_dodging:
		start_dodge()

	# Jump Input (Space - supports Double Jump)
	if Input.is_action_just_pressed(\"jump\") and jump_count < max_jumps:
		velocity.y = jump_velocity
		jump_count += 1

	# --- STATE HANDLING ---
	if is_dodging:
		dodge_timer -= delta
		velocity.x = facing_direction * dodge_speed
		if dodge_timer <= 0:
			end_dodge()
	elif is_attacking:
		# Slow down movement during the attack pose
		velocity.x = direction * (speed * 0.5) 
	else:
		velocity.x = direction * speed

	# --- VISUALS ---
	if sprite:
		sprite.flip_h = facing_direction < 0
	
	# Visual feedback for dodging (transparency)
	modulate.a = 0.5 if is_dodging else 1.0

	# Move character and handle collisions
	move_and_slide()

# =============================
# HEALTH & DAMAGE LOGIC
# =============================
func take_damage(amount: float):
	current_health -= amount
	
	# Update HUD
	if health_bar:
		health_bar.value = current_health
	
	# Check for 40% transformation trigger
	if current_health <= (max_health * 0.4) and not has_transformed:
		transform_to_p2()
	
	if current_health <= 0:
		die()

func transform_to_p2():
	has_transformed = true
	if sprite and transformed_texture:
		sprite.texture = transformed_texture
		# Update the \"original\" texture so it doesn't switch back to normal pose after attacking
		original_texture = transformed_texture
		print(\"Naruto transformed to P2 pose!\")

func die():
	print(\"Naruto defeated!\")
	get_tree().reload_current_scene()

# =============================
# ATTACK LOGIC
# =============================
func start_attack():
	if is_attacking: return 
	
	is_attacking = true
	
	# Switch to attack texture and scale up
	if sprite and attack_texture:
		sprite.texture = attack_texture
		sprite.scale = attack_scale 
	
	# Attack Detection logic
	if has_node(\"AttackArea\"):
		var hit_list = $AttackArea.get_overlapping_bodies()
		for body in hit_list:
			# Hit enemies like Itachi or Pain
			if body.is_in_group(\"Enemies\") and body.has_method(\"take_damage\"):
				body.take_damage(1)
	
	await get_tree().create_timer(attack_duration).timeout
	end_attack()

func end_attack():
	is_attacking = false
	if sprite:
		sprite.texture = original_texture
		sprite.scale = normal_scale 

# =============================
# DODGE & BOOST LOGIC
# =============================
func start_dodge():
	is_dodging = true
	dodge_timer = dodge_time
	set_collision_mask_value(2, false)

func end_dodge():
	is_dodging = false
	set_collision_mask_value(2, true)

func apply_jump_boost(boost_force: float):
	velocity.y = boost_force
"

